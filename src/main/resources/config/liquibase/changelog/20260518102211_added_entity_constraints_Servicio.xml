<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">
    <!--
        Added the constraints for entity Servicio.
    -->
    <changeSet id="20260518102211-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="cliente_id"
                                 baseTableName="servicio"
                                 constraintName="fk_servicio__cliente_id"
                                 referencedColumnNames="id"
                                 referencedTableName="cliente"
                                 />

        <addForeignKeyConstraint baseColumnNames="tarifa_id"
                                 baseTableName="servicio"
                                 constraintName="fk_servicio__tarifa_id"
                                 referencedColumnNames="id"
                                 referencedTableName="tarifa"
                                 />

        <addForeignKeyConstraint baseColumnNames="servicio_id"
                                 baseTableName="rel_servicio__trabajadores"
                                 constraintName="fk_rel_servicio__trabajadores__servicio_id"
                                 referencedColumnNames="id"
                                 referencedTableName="servicio"
                                 />

        <addForeignKeyConstraint baseColumnNames="trabajadores_id"
                                 baseTableName="rel_servicio__trabajadores"
                                 constraintName="fk_rel_servicio__trabajadores__trabajadores_id"
                                 referencedColumnNames="id"
                                 referencedTableName="trabajador"
                                 />
    </changeSet>
</databaseChangeLog>
